{
  "name": "teleport-contest",
  "version": "1.0.0",
  "description": "The Teleport Coding Challenge — Port NetHack C to JavaScript",
  "type": "module",
  "scripts": {
    "test": "node --test scripts/*.test.mjs",
    "check:monsters": "node scripts/generate-monsters.mjs --check",
    "check:objects": "node scripts/generate-objects.mjs --check",
    "check:symbols": "node scripts/generate-symbol-data.mjs --check",
    "check:themerooms": "node scripts/generate-themeroom-data.mjs --check",
    "quality": "node scripts/quality-status.mjs",
    "score": "bash frozen/score.sh",
    "play": "echo 'Open index.html in a browser to play'"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
